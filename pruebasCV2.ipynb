   "source": [
    "import cv2\n",
    "cap = cv2.VideoCapture(0)\n",
    "\n",
    "while True:\n",
    "    ret, frame = cap.read()\n",
    "\n",
    "    if ret == True:\n",
    "        cv2.imshow('Stream de prueba', frame)\n",
    "\n",
    "    else:\n",
    "        break\n",
    "\n",
    "cap.relase()\n",
    "cv2.destroyAllWindows()"
   ]
  }
 ],
